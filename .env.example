# ─── Thank You Jesus — Environment Variables ───────────────────────────────
# Copy this to .env.local for local development
# Add these in Vercel Dashboard → Project → Settings → Environment Variables

# Anthropic API Key (required for AI chat)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Stripe (required for Premium subscriptions)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
# Create a "Thank You Jesus Premium" product with 2 prices
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Your app URL (for Stripe redirect after payment)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
